---
import formatDate from "@/utils/formatDate";

type Props = {
  title: string;
  description: string;
  slug: string;
  publishedAt: Date;
  lang: string;
  isDraft: boolean;
};

const { title, description, publishedAt, slug, isDraft, lang } = Astro.props;
const flag = `/flags/${lang}.png`

---
<a
  class="group flex flex-col gap-2 border-t border-neutral-700 py-4 transition-all hover:text-neutral-100"
  href={!isDraft ? `/activity/${slug}` : null}
>
  <div class="flex w-full items-center justify-between">
    <h2 class="text-lg flex items-center gap-x-2">
      {title}{" "}
      {lang && <img src={flag} class="h-5"/>}
    </h2>
    <div class="flex flex-row items-center gap-4">
      <p>{formatDate(publishedAt)}</p>
      {!isDraft &&
        <svg
        width="18"
        height="18"
        viewBox="0 0 18 18"
        fill="none"
        class="transition-all duration-300 group-hover:translate-x-1"
      >
        <path
          d="M5.25 12.75L12.75 5.25"
          stroke="#999999"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
        <path
          d="M5.25 5.25H12.75V12.75"
          stroke="#999999"
          stroke-linecap="round"
          stroke-linejoin="round"
        />
      </svg>
      }
    </div>
  </div>
  <p>{description}</p>
</a>