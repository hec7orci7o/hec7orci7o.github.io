---
import { getCollection } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import PostCard from "@/components/posts/PostCard.astro";

const cheatsheets = (await getCollection("cheatsheets"))
---

<Layout title="All Posts">
  <main class="flex flex-col gap-20">
    <h1 class="text-2xl text-neutral-100">Cheatsheet</h1>

    <article class="flex flex-col gap-4">
      {cheatsheets.length === 0 && 
        <p>Soon, stay connected 👀...</p>
      }
      {cheatsheets
        .map((cheatsheet) => (
          <PostCard 
            title={cheatsheet.data.title}
            description={""}
            slug={cheatsheet.slug}
            publishedAt={new Date("2024-03-03")}
            isPublished={true}
          />
        ))}
    </article>
  </main>
</Layout>
